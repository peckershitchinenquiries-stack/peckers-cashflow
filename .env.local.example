NEXT_PUBLIC_SUPABASE_URL=your-supabase-project-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Server-only. Project Settings > API > service_role key.
# Required for creating manager/employee login accounts from the app.
# NEVER prefix this with NEXT_PUBLIC_ — it must never reach the browser.
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
