NEXT_PUBLIC_SUPABASE_URL=your-supabase-project-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Server-only. Project Settings > API > service_role key.
# Required for creating manager/employee login accounts from the app, AND for
# the automatic alert scan that runs when crew clock in/out.
# NEVER prefix this with NEXT_PUBLIC_ — it must never reach the browser.
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Optional: email alert notifications via Resend (https://resend.com).
# Leave unset to disable email — alert scanning still works without it.
# Enable + set recipients in the app under Settings > Alerts & Compliance.
RESEND_API_KEY=your-resend-api-key
# Verified Resend sender, e.g. "Peckers Alerts <alerts@yourdomain.co.uk>"
ALERT_EMAIL_FROM=Peckers Alerts <alerts@yourdomain.co.uk>

# ============================================================================
# VM Analytics Module — separate Supabase project (NOT the cashflow DB)
# ============================================================================

# Optional: Claude-powered insights (if set, commentary is Claude-written; otherwise rule-based)
ANTHROPIC_API_KEY=[your-anthropic-api-key-for-production]
ANTHROPIC_MODEL=claude-haiku-4-5-20251001
