NEXT_PUBLIC_SUPABASE_URL=your-supabase-project-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Server-only. Project Settings > API > service_role key.
# Required for creating manager/employee login accounts from the app, AND for
# the automatic alert scan that runs when crew clock in/out.
# NEVER prefix this with NEXT_PUBLIC_ — it must never reach the browser.
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ============================================================================
# Clock-in / clock-out browser push reminders
# ============================================================================

# Generate a keypair once with:  npx web-push generate-vapid-keys
# The PUBLIC key is also read by the browser (NEXT_PUBLIC_) to subscribe.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
# Contact URI the push services can reach you at (optional but recommended).
VAPID_SUBJECT=mailto:you@yourdomain.co.uk

# Shared secret guarding the cron endpoints (missing-cash-entry, shift-reminders).
# Must match the CRON_SECRET given to the external scheduler (GitHub Actions /
# cron-job.org). The shift-reminders job should POST every ~5 minutes.
CRON_SECRET=your-long-random-cron-secret

# Email via Resend (https://resend.com).
# Optional for alerts (leave unset to disable them — alert scanning still works),
# but REQUIRED for self-service password reset: without it, staff who forget
# their password can only get back in by asking an admin to reset it.
# Enable alert emails + set recipients under Settings > Alerts & Compliance.
RESEND_API_KEY=your-resend-api-key
# Verified Resend sender, e.g. "Peckers Alerts <alerts@yourdomain.co.uk>"
ALERT_EMAIL_FROM=Peckers Alerts <alerts@yourdomain.co.uk>

# Public base URL of the deployed app, e.g. https://rota.peckers-app.co.uk
# Used to build absolute links in outbound email (password-reset links). Falls
# back to the request's own origin if unset, so set it in production to be sure
# reset links point at the real site rather than whatever host served the form.
APP_URL=https://your-app-domain.co.uk

# ============================================================================
# VM Analytics Module — separate Supabase project (NOT the cashflow DB)
# ============================================================================

# Optional: Claude-powered insights (if set, commentary is Claude-written; otherwise rule-based)
ANTHROPIC_API_KEY=[your-anthropic-api-key-for-production]
ANTHROPIC_MODEL=claude-haiku-4-5-20251001
